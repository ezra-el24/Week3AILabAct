def check_borrowing(overdue_books, status):
    if overdue_books == "yes":
        return "Not allowed: overdue books"
    elif status == "suspended":
        return "Not allowed: suspended account"
    else:
        return "Borrowing allowed"

successful_borrowers = 0

while True:
    name = input("Enter student name (or type 'exit' to quit): ").strip()
    if name.lower() == "exit":
        break

    overdue = input("Do you have overdue books? (yes/no): ").strip().lower()
    status = input("Enter your status (active/suspended): ").strip().lower()
    books_requested = int(input("How many books do you want to borrow?: ").strip())

    result = check_borrowing(overdue, status)

    if result == "Borrowing allowed":
        if books_requested == 0:
            print("You requested 0 books. No borrowing processed.")
        elif books_requested > 3:
            print("You can only borrow up to 3 books. Borrowing 3 instead.")
            successful_borrowers += 1
        else:
            print(f"Borrowing {books_requested} book(s). Approved.")
            successful_borrowers += 1
    else:
        print(result)

print(f"Total successful borrowers today: {successful_borrowers}")
